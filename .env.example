# ===== 最小可用配置（改这3行就能跑） =====
NOVEL_LLM_PROVIDER=qwen
QWEN_API_KEY=替换成你的key
QWEN_MODEL=qwen3-max-2026-01-23

# ===== 以下全部可选 =====

# LLM 参数（不写有默认值）
NOVEL_LLM_TEMPERATURE=0.7
NOVEL_LLM_MAX_TOKENS=4096
NOVEL_WORKFLOW_MODE=standard
NOVEL_REVIEW_DEPTH=core

# ===== Ollama 本地（二选一） =====
# NOVEL_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:72b

# ===== Embedding（RAG 向量检索，不用 BM25 可跳过） =====
# EMBED_BASE_URL=https://api-inference.modelscope.cn/v1
# EMBED_MODEL=Qwen/Qwen3-Embedding-8B
# EMBED_API_KEY=

# ===== Rerank（精排，不用可跳过） =====
# RERANK_BASE_URL=https://api.jina.ai/v1
# RERANK_MODEL=jina-reranker-v3
# RERANK_API_KEY=

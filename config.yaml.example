# NovelWriter 配置文件示例
# 复制为 config.yaml 并修改为你的配置

llm:
  provider: qwen  # qwen | ollama | openai（百炼平台等 OpenAI 兼容端点用 openai）
  model: qwen3-max-2026-01-23  # 你使用的模型名
  api_key: "${QWEN_API_KEY}"  # 从环境变量读取
  base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  temperature: 0.7
  max_tokens: 4096
  timeout: 120
  retry_count: 3

embedding:
  provider: qwen
  model: "Qwen/Qwen3-Embedding-8B"
  api_key: "${EMBED_API_KEY}"
  base_url: "https://api-inference.modelscope.cn/v1"

reranker:
  provider: jina
  model: "jina-reranker-v3"
  api_key: "${RERANK_API_KEY}"
  base_url: "https://api.jina.ai/v1"

workflow:
  default_mode: standard  # standard | fast | minimal
  review_depth: core      # core | full
  auto_polish: true
  git_backup: true
  chapter_min_words: 2000
  chapter_max_words: 2500

agents:
  context_agent:
    temperature: 0.8
    max_tokens: 4096
  data_agent:
    temperature: 0.3
    max_tokens: 2048
  consistency_checker:
    temperature: 0.3
    max_tokens: 2048
  continuity_checker:
    temperature: 0.3
    max_tokens: 2048
  ooc_checker:
    temperature: 0.3
    max_tokens: 2048
  reader_pull_checker:
    temperature: 0.3
    max_tokens: 2048
